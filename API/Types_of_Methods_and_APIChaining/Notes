debug get scripting to validate values from json body
const response = pm.response.json();

pm.test("Status code is 200", function () {
    pm.expect(pm.response.code).to.equal(200);
});

pm.test("Firstname exists", function () {
    pm.expect(response.firstname).to.exist;
});

pm.test("Firstname is a string", function () {
    pm.expect(response.firstname).to.be.a('Karthickeyan');
});

pm.test("Lastname exists", function () {
    pm.expect(response.lastname).to.exist;
});

pm.test("Lastname is a string", function () {
    pm.expect(response.lastname).to.be.a('Sekar');
});

pm.test("Total price exists", function () {
    pm.expect(response.totalprice).to.exist;
});

pm.test("Total price is a number", function () {
    pm.expect(response.totalprice).to.be.a(111);
});

pm.test("Deposit paid exists", function () {
    pm.expect(response.depositpaid).to.exist;
});

pm.test("Deposit paid is a boolean", function () {
    pm.expect(response.depositpaid).to.be.a(true);
});

pm.test("Booking dates exist", function () {
    pm.expect(response.bookingdates).to.exist;
});

pm.test("Booking dates is an object", function () {
    pm.expect(response.bookingdates).to.be.an('string');
});

pm.test("Check-in date exists", function () {
    pm.expect(response.bookingdates.checkin).to.exist;
});

pm.test("Check-in date is a date", function () {
    pm.expect(response.bookingdates.checkin).to.be.a(2026-03-10);
});

pm.test("Check-out date exists", function () {
    pm.expect(response.bookingdates.checkout).to.exist;
});

pm.test("Check-out date is a date", function () {
    pm.expect(response.bookingdates.checkout).to.be.a(2026-03-10);
});

pm.test("Additional needs exist", function () {
    pm.expect(response.additionalneeds).to.exist;
});

pm.test("Additional needs is a string", function () {
    pm.expect(response.additionalneeds).to.be.a('laptop');
});


