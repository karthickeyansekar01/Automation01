postman basic post-response script validation
---------------------------------------------
			// Validating response status code
pm.test("Status code is 200", function () {
    pm.expect(pm.response.code).to.equal(200);
});

			// Validating response status message
pm.test("Response message is OK", function () {
    pm.expect(pm.response.status).to.equal("OK");
});

			// Validating json response body object values are the same as expected
let res = pm.response.json();
pm.environment.set("res",res);

pm.test("JSON response body has total price", function () {
    pm.expect(res.booking.totalprice).to.exist;
    pm.expect(res.booking.totalprice).to.be.a('number');
});

pm.test("JSON response body has firstname", function () {
    pm.expect(res.booking.firstname).to.exist;
    pm.expect(res.booking.firstname).to.be.a('string');
});

pm.test("JSON response body has booking.bookingdates.checkin", function () {
    pm.expect(res.booking.bookingdates.checkin).to.exist;
    pm.expect(res.booking.bookingdates.checkin).to.be.a('string');
});

			// Local Variable - only available for this collection
let bookingID = res.bookingid;
console.log(bookingID);

			// Environment variable - available for all collections
pm.environment.set("BookingID",bookingID);











